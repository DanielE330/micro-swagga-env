# ──── External ports (host → container) ────
CADDY_HTTP_PORT=8081
CADDY_HTTPS_PORT=8443
POSTGRES_EXTERNAL_PORT=5433

# ──── Database ────
DB_HOST=db
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/app_db

# ──── JWT ────
SECRET_KEY=supersecretkey
ALGORITHM=HS256

# ──── Docs service: service discovery ────
# Format: host:port=prefix|openapi_path (openapi_path optional, defaults to /openapi.json)
SERVICES=auth_service:8002=/auth,user_service:8001=/users,products_service:8080=/products,orders_service:3000=/orders,notifications_service:8003=/notifications,reviews_service:8004=/reviews,categories_service:3001=/categories|/api-docs,tags_service:3002=/tags|/swagger.json,inventory_service:8085=/inventory|/v3/api-docs,shipping_service:5000=/shipping|/swagger/v1/swagger.json,payments_service:8086=/payments|/swagger/doc.json,comments_service:3003=/comments|/api/swagger_doc,coupons_service:8087=/coupons|/api/doc.json,analytics_service:8088=/analytics|/api-doc/openapi.json
ACCESS_TOKEN_EXPIRE_MINUTES=120